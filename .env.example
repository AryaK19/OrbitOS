TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_user_id_here
AGENT_PASSWORD=


GIT_TOKEN=your_git_token_here

# Working directory for the agent (required)
# This is the default directory where commands run.
WORKING_DIR=/Users/yourname

# Sandbox allowed paths (required)
# Comma-separated list of directories the agent can access for file operations.
SANDBOX_ALLOWED_PATHS=/Users/yourname,/tmp

# Google Gemini API Key (required for AI features)
# Used by the LangGraph agent for Gemini models.
# Generate at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key

# Optional: OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_key

# Optional: Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=your_anthropic_key