# Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Telegram Bot Token (required)
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts to create a bot
# 3. Copy the token provided by BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (required)
# This is used for the whitelist and admin permissions in config.yaml.
# To find your ID: message @userinfobot on Telegram — it replies with your numeric ID.
TELEGRAM_USER_ID=your_user_id_here

# Password for non-whitelisted Telegram users (optional)
# Whitelisted users (configured in config/config.yaml) don't need this.
# Non-whitelisted users must run /login <password> in the bot to authenticate.
# Leave empty or remove to disable password-based access.
AGENT_PASSWORD=

# GitHub Personal Access Token (optional)
# Used for GitHub integrations.
# Generate at: https://github.com/settings/tokens
GIT_TOKEN=your_git_token_here

# Working directory for the agent (required)
# This is the default directory where commands run.
WORKING_DIR=/Users/yourname

# Sandbox allowed paths (required)
# Comma-separated list of directories the agent can access for file operations.
SANDBOX_ALLOWED_PATHS=/Users/yourname,/tmp

# Google Gemini API Key (required for AI features)
# Used by the LangGraph agent for Gemini models.
# Generate at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key

# Optional: OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_key

# Optional: Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=your_anthropic_key